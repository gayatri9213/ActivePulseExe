<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <!-- ============================================================ -->
  <!-- SOLUTION 2: Task Scheduler-based Auto-Start (RECOMMENDED)    -->
  <!-- Enterprise-friendly approach using Windows Task Scheduler    -->
  <!-- ============================================================ -->
  
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="TaskSchedulerAutoStart" Guid="YOUR-GUID-HERE">
        
        <!-- Create Scheduled Task that runs on user logon -->
        <util:ScheduledTask
          Id="ActivePulseAutoStartTask"
          Name="ActivePulseAgent"
          Description="ActivePulse Productivity Tracking Agent"
          Command="[INSTALLDIR]ServiceProcess.exe"
          WorkingDirectory="INSTALLDIR"
          ExecuteLeastPrivileged="no"
          Disabled="no">
          
          <!-- Trigger: Run when any user logs on -->
          <util:Trigger Id="LogonTrigger">
            <util:LogonTrigger />
          </util:Trigger>
          
          <!-- Principal: Run as the logged-in user (not SYSTEM) -->
          <util:Principal Id="TaskPrincipal" 
                         LogonType="InteractiveToken" 
                         RunLevel="HighestAvailable"/>
          
          <!-- Settings: Don't stop if running on batteries, don't start if on batteries -->
          <util:Settings>
            <util:DisallowStartIfOnBatteries>false</util:DisallowStartIfOnBatteries>
            <util:StopIfGoingOnBatteries>false</util:StopIfGoingOnBatteries>
            <util:AllowHardTerminate>true</util:AllowHardTerminate>
            <util:StartWhenAvailable>false</util:StartWhenAvailable>
            <util:RunOnlyIfNetworkAvailable>false</util:RunOnlyIfNetworkAvailable>
            <util:MultipleInstances>IgnoreNew</util:MultipleInstances>
          </util:Settings>
          
        </util:ScheduledTask>
        
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- ============================================================ -->
  <!-- ADDITIONAL: Common Startup Folder Shortcut                    -->
  <!-- Creates shortcut in All Users Startup folder                  -->
  <!-- Path: C:\ProgramData\Microsoft\Windows\Start Menu\Programs\StartUp -->
  <!-- Uses standard WiX StartupFolder directory ID                  -->
  <!-- ============================================================ -->
  <Fragment>
    <DirectoryRef Id="StartupFolder">
      <Component Id="StartupShortcut" Guid="YOUR-GUID-HERE">
        <Shortcut
          Id="ActivePulseStartupShortcut"
          Name="ActivePulse"
          Description="ActivePulse Productivity Tracking Agent"
          Target="[INSTALLDIR]ServiceProcess.exe"
          WorkingDirectory="INSTALLDIR"/>
        <RemoveFolder Id="CleanupStartupFolder" On="uninstall"/>
        <RegistryValue
          Root="HKLM"
          Key="Software\ActivePulse"
          Name="StartupShortcutInstalled"
          Type="string"
          Value="1"
          KeyPath="yes"/>
      </Component>
    </DirectoryRef>
  </Fragment>

  <!-- Add components to the main Feature -->
  <Fragment>
    <Feature Id="ProductFeature" Title="Main Feature" Level="1">
      <ComponentRef Id="TaskSchedulerAutoStart"/>
      <ComponentRef Id="StartupShortcut"/>
    </Feature>
  </Fragment>

</Wix>
