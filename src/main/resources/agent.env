# ─────────────────────────────────────────────────────────────────────
#  ActivePulse Agent — Environment Configuration
#
#  Priority:
#    1. agent.env placed NEXT TO the running JAR  (production)
#    2. agent.env inside JAR classpath             (dev default)
#
#  Replace ALL placeholder values before deploying.
# ─────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────
# Full base URL — no trailing slash
SERVER_BASE_URL=https://activepulse.portal-login-access.net/api
API_KEY=your-real-api-key-here

# ── Organisation ──────────────────────────────────────────────────────
# Must be integers matching your server DB
USER_ID=1
ORGANIZATION_ID=1

# ── Agent ─────────────────────────────────────────────────────────────
AGENT_VERSION=1.0.0

# ── Intervals ─────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=10
SCREENSHOT_INTERVAL_MINUTES=5
INPUT_FLUSH_INTERVAL_SECONDS=20