<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_DIR" value="${user.home}/.activepulse/logs"/>

    <!-- ─── Console ──────────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{30} — %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ─── Day-wise rolling file ─────────────────────────────────── -->
    <!-- Active file: activepulse.log                                  -->
    <!-- Rolled file: logs_2026-03-18.log, logs_2026-03-19.log ...     -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/activepulse.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- One file per day, named logs_YYYY-MM-DD.log -->
            <fileNamePattern>${LOG_DIR}/logs_%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{30} — %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ─── Root ──────────────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>